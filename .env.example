# AarogyaMitra Environment Variables

# SMS Service Configuration
# Supported providers: mock, msg91, textlocal, twilio, firebase
VITE_SMS_PROVIDER=mock

# For MSG91 (Popular in India)
VITE_SMS_API_KEY=your_msg91_api_key_here
VITE_SMS_TEMPLATE_ID=your_template_id_here
VITE_SMS_SENDER_ID=AROGYA

# For TextLocal
# VITE_SMS_API_KEY=your_textlocal_api_key_here
# VITE_SMS_SENDER_ID=AROGYA

# For Twilio (requires backend implementation)
# VITE_SMS_API_KEY=your_twilio_account_sid_here
# VITE_SMS_AUTH_TOKEN=your_twilio_auth_token_here

# Development Settings
VITE_APP_ENV=development
VITE_API_BASE_URL=http://localhost:3000

# Database Configuration (for future use)
# VITE_SUPABASE_URL=your_supabase_url_here
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
