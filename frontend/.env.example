# --- FRONTEND (Vercel) ---
# The URL where your backend is hosted (e.g., https://medinova-backend.onrender.com)
VITE_API_BASE_URL=http://localhost:5000

# --- BACKEND (Render) ---
# Your MongoDB connection string
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.mongodb.net/medinova

# The port where the server will run (Render provides this automatically)
PORT=5000

# Optional: Gemini API Key for AI features (if used)
GEMINI_API_KEY=your_gemini_api_key
